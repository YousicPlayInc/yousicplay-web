# ============================================================================
# YousicPlay Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================================

# ── Supabase (REQUIRED) ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe (REQUIRED for checkout) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin Access (REQUIRED) ─────────────────────────────────────────────
# Comma-separated emails that can access /admin
ADMIN_EMAILS=manage@yousicplay.com

# ── Analytics ────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_META_PIXEL_ID=1234567890  # Add when Facebook access obtained

# ── Klaviyo (email marketing) ────────────────────────────────────────────
KLAVIYO_API_KEY=pk_...
KLAVIYO_MAIN_LIST_ID=AbCdEf

# ── Spotify OAuth (optional — for music profiles) ────────────────────────
# Register at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your-spotify-client-id

# ── Thinkific (legacy — for enrollment API if still used) ────────────────
# THINKIFIC_API_KEY=your-api-key
# THINKIFIC_SUBDOMAIN=yousicplay
